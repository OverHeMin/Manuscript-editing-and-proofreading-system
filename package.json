{
  "name": "medical-manuscript-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "inspect:codex-logs": "node ./scripts/codex-log-cleanup.mjs",
    "cleanup:codex-logs": "node ./scripts/codex-log-cleanup.mjs --apply",
    "lint": "pnpm --parallel lint",
    "test:codex-log-cleanup": "node --test scripts/codex-log-cleanup.spec.mjs",
    "test:production-release-contract": "node --test scripts/production-release-contract.spec.mjs",
    "test:local-pr-gate": "node --test scripts/local-pr-gate.spec.mjs",
    "verify:production-postdeploy": "node ./scripts/production-release-contract.mjs postdeploy",
    "verify:production-preflight": "node ./scripts/production-release-contract.mjs predeploy",
    "verify:production-preflight:strict": "node ./scripts/production-release-contract.mjs predeploy --check-migrations",
    "verify:production-upgrade-rehearsal": "node ./scripts/production-release-contract.mjs rehearsal",
    "verify:pr-gate": "node ./scripts/local-pr-gate.mjs",
    "verify:manuscript-workbench": "node ./scripts/run-manuscript-workbench-gate.mjs",
    "typecheck": "pnpm --parallel typecheck",
    "test": "pnpm --parallel test"
  },
  "workspaces": ["apps/*", "packages/*"]
}
