{
  "name": "@medical/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:persistent",
    "dev:demo": "tsx watch ./src/http/dev-server.ts",
    "dev:persistent": "tsx watch ./src/http/prod-server.ts",
    "lint": "pnpm run typecheck",
    "serve": "pnpm run serve:persistent",
    "serve:demo": "tsx ./src/http/dev-server.ts",
    "serve:persistent": "tsx ./src/http/prod-server.ts",
    "preflight:persistent": "tsx ./src/ops/persistent-startup-preflight.ts",
    "recover:governed-orchestration": "tsx ./src/ops/recover-governed-execution-orchestration.ts",
    "db:seed-qwen-module-routing": "tsx ./src/database/scripts/seed-qwen-module-routing.ts",
    "smoke:boot": "tsx ./src/ops/smoke-boot.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx ./test/run-tests.ts",
    "db:migrate": "tsx ./src/database/scripts/migrate.ts",
    "db:manage-user": "tsx ./src/database/scripts/manage-user.ts",
    "db:migration-doctor": "tsx ./src/database/scripts/migration-doctor.ts"
  },
  "dependencies": {
    "@medical/contracts": "workspace:*",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "prisma": "^6.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
