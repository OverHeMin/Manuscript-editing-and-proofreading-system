# Demo runtime:
# - APP_ENV=local
# - use `pnpm --filter @medical/api run serve:demo`
# - use `pnpm --filter @medical/api run dev:demo` for watch mode
# - loopback only, seeded in-memory data
#
# Persistent runtime:
# - APP_ENV=development|test|staging|production
# - use `pnpm --filter @medical/api run serve`
# - use `pnpm --filter @medical/api run dev` for watch mode
# - PostgreSQL-backed auth + governance registries
# - when `UPLOAD_ROOT_DIR` is omitted, uploads default to `.local-data/uploads/<app-env>`
# - `ONLYOFFICE_JWT_SECRET=change-me-in-prod` is invalid for staging/production
# - manuscripts/assets/learning mainline are still mixed-mode in this phase
APP_ENV=local
API_PORT=3001
API_HOST=127.0.0.1
API_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15432/medical_api?schema=public
DATABASE_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:15432/postgres
REDIS_URL=redis://127.0.0.1:56379/0
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:59000
OBJECT_STORAGE_BUCKET=medical-manuscripts-local
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin123
OBJECT_STORAGE_FORCE_PATH_STYLE=true
ONLYOFFICE_URL=http://127.0.0.1:58080
ONLYOFFICE_JWT_SECRET=change-me-in-prod
ONLYOFFICE_MODE=evaluation_readonly
LIBREOFFICE_BINARY=soffice
